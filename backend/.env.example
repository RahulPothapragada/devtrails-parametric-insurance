# ── FlowSecure Backend — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Database (SQLite — zero config, file auto-created on first run) ──────────
DATABASE_URL=sqlite+aiosqlite:///./flowsecure.db

# ── JWT Auth ─────────────────────────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-32-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── External APIs (ALL OPTIONAL — app runs in sandbox/mock mode without keys) ──

# OpenWeatherMap (free tier: 1,000 calls/day)
# https://openweathermap.org/api
OPENWEATHER_API_KEY=

# WAQI Air Quality Index
# https://aqicn.org/data-platform/token/
WAQI_API_KEY=

# TomTom Traffic
# https://developer.tomtom.com/
TOMTOM_API_KEY=

# NewsAPI (social disruption signals)
# https://newsapi.org/
NEWSAPI_KEY=

# ── Razorpay Payment Gateway (Test Mode) ─────────────────────────────────────
# Get test keys from https://dashboard.razorpay.com/
# If left blank the app uses built-in sandbox simulation — no real Razorpay needed
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── App Config ────────────────────────────────────────────────────────────────
ENV=development
DEBUG=true
