# FlowSecure Frontend — environment variables
# Copy this file:  cp .env.example .env  then fill in your values

# Backend API base URL
# Development:   http://127.0.0.1:8000/api
# Production:    https://your-render-or-railway-url.com/api
VITE_API_URL=http://127.0.0.1:8000/api

# OpenWeatherMap API key (free tier — https://openweathermap.org/api)
VITE_OPENWEATHER_API_KEY=your_openweathermap_key_here

# Google Maps API key (enable Maps JavaScript API in Google Cloud Console)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key_here
